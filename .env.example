# FairBet Lab — variables de entorno
# Copia a .env:  cp .env.example .env

# --- Django ---
DEBUG=1
SECRET_KEY=cambiar-en-produccion-usa-una-clave-larga-y-aleatoria
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# --- PostgreSQL (servicio "db" en docker-compose) ---
POSTGRES_DB=fairbet
POSTGRES_USER=fairbet
POSTGRES_PASSWORD=fairbet_dev
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis (Celery + Channels) ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Host del channel layer (WebSockets)
CHANNEL_LAYERS_HOST=redis
CHANNEL_LAYERS_PORT=6379

# --- Apuestas in-play (opcional) ---
# Segundos que un mercado queda suspendido tras un gol
# MERCADO_SUSPENSION_SEGUNDOS=30
